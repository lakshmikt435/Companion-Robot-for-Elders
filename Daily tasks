# Weather API
def get_weather(location="Angamaly"):
    api_key = "cc7d6ae6e40144649e855822240411"
    base_url = "http://api.weatherapi.com/v1/current.json"
    url = f"{base_url}?key={api_key}&q={location}"

    try:
        response = requests.get(url)
        response.raise_for_status()  # Check for HTTP errors
        data = response.json()

        location_name = data.get("location", {}).get("name", "Unknown Location")
        temperature = data.get("current", {}).get("temp_c", "Unavailable")
        condition = data.get("current", {}).get("condition", {}).get("text", "Unavailable")

        print(f"Weather in {location_name}:")
        print(f"Temperature: {temperature} C")
        print(f"Condition: {condition}")

        engine.say(f"The current weather in {location_name} is as follows.")
        if temperature != "Unavailable":
            speak(f"The temperature is {temperature} degrees Celsius.")
        else:
            speak("Temperature information is currently unavailable.")
        speak(f"The weather condition is {condition}.")
        
    except requests.exceptions.RequestException as e:
        error_message = f"Error fetching data from Weather API: {e}"
        print(error_message)
        speak(error_message)

