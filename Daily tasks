def load_progress():
    """Load verses progress from the file."""
    if progress_file.exists():
        with progress_file.open("r") as file:
            return json.load(file)
    return {"read_verses": []}

def save_progress(progress):
    """Save verses progress to the file."""
    with progress_file.open("w") as file:
        json.dump(progress, file)
def configure_tts():
    """Configure the text-to-speech engine for clear and slow reading."""
    engine = pyttsx3.init()
    # Set properties for clarity and slow speech
    engine.setProperty("rate", 140)  # Adjust rate (default is around 200 wpm; lower is slower)
    engine.setProperty("volume", 0.9)  # Set volume (0.0 to 1.0)
    return engine



def read_daily_verse():
    """Read a daily Bible verse."""
    progress = load_progress()
    read_verses = progress.get("read_verses", [])
    
    # Check if all verses have been read
    if len(read_verses) == len(bible_verses):
        print("All verses have been read. Resetting the list.")
        read_verses = []

    # Select a random unread verse
    unread_verses = [verse for verse in bible_verses if verse not in read_verses]
    verse = random.choice(unread_verses)
    read_verses.append(verse)

    # Save progress
    progress["read_verses"] = read_verses
    save_progress(progress)

    # Read the verse with text-to-speech
    engine = configure_tts()
    print(f"Today's Bible verse: {verse}")
    speak(verse)
    engine.runAndWait()
